<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Reset Password - Admin Homostay</title>
  <meta name="csrf-token" content="<%= form_authenticity_token %>">
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif; -webkit-font-smoothing: antialiased; -moz-osx-font-smoothing: grayscale; }
  </style>
</head>
<body class="min-h-screen bg-gradient-to-br from-slate-50 to-slate-100 flex items-center justify-center p-4">
  <div class="w-full max-w-md mx-auto mt-20">
    <div class="bg-white rounded-xl shadow-md p-6">
      <div class="text-center mb-6">
        <h1 class="text-2xl font-bold text-slate-900 mb-2">Reset your password</h1>
        <p class="text-sm text-slate-600">Enter your new password below.</p>
      </div>

      <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put, class: "space-y-5" }) do |f| %>
        <%= f.hidden_field :reset_password_token %>

        <% if alert %>
          <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg text-sm">
            <%= alert %>
          </div>
        <% end %>

        <% if notice %>
          <div class="bg-blue-50 border border-blue-200 text-blue-700 px-4 py-3 rounded-lg text-sm">
            <%= notice %>
          </div>
        <% end %>

        <% if resource.errors.any? %>
          <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg text-sm">
            <%= resource.errors.full_messages.join(", ") %>
          </div>
        <% end %>

        <div>
          <%= f.label :password, "New password", class: "block text-sm font-medium text-slate-700 mb-1.5" %>
          <%= f.password_field :password,
                autofocus: true,
                autocomplete: "new-password",
                required: true,
                minlength: 6,
                class: "w-full rounded-md border border-slate-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent",
                placeholder: "Enter new password" %>
        </div>

        <div>
          <%= f.label :password_confirmation, "Confirm new password", class: "block text-sm font-medium text-slate-700 mb-1.5" %>
          <%= f.password_field :password_confirmation,
                autocomplete: "new-password",
                required: true,
                minlength: 6,
                class: "w-full rounded-md border border-slate-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent",
                placeholder: "Confirm new password" %>
        </div>

        <div>
          <%= f.submit "Change my password", class: "w-full bg-indigo-600 hover:bg-indigo-700 text-white font-semibold rounded-md py-2 transition-colors cursor-pointer focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2" %>
        </div>
      <% end %>

      <div class="mt-6 text-center">
        <%= link_to "Back to sign in", new_session_path(resource_name), class: "text-indigo-600 text-sm hover:text-indigo-700 font-medium" %>
      </div>
    </div>

    <div class="mt-6 text-center text-sm text-slate-500">
      <p>© <%= Date.current.year %> Homostay. All rights reserved.</p>
    </div>
  </div>
</body>
</html>
