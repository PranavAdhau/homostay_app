# The canonical container build uses the repository root as its build context.
# Keep this file aligned with the root `.dockerignore` for direct server-only
# builds, but do not treat it as the primary source of truth.

/.git/
/.bundle
/.env*
!/.env*.erb
/config/master.key
/config/credentials/*.key
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep
/tmp/pids/*
!/tmp/pids/.keep
/storage/*
!/storage/.keep
/tmp/storage/*
!/tmp/storage/.keep
/node_modules/
/public/assets
/public/vite
/public/index.html
