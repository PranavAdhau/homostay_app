#!/usr/bin/env bash
set -euo pipefail

# Wait for PostgreSQL before starting the web server.
# Database initialization (db:prepare) is intentionally handled
# by scripts/docker-db-setup.sh during deployment.
if [[ "${1:-}" == "bundle" && "${2:-}" == "exec" ]]; then
  if [[ "${3:-}" == "puma" ]]; then
    /app/server/scripts/wait-for-postgres.sh
  fi
fi

exec "$@"
