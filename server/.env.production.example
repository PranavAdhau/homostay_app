RAILS_ENV=production
SERVICE_MODE=web
RUN_SIDEKIQ_IN_WEB=true
BACKEND_URL=https://your-real-domain.com
FRONTEND_URL=https://your-real-domain.com
APP_HOSTS=your-real-domain.com,www.your-real-domain.com
SECRET_KEY_BASE=change-me
HOMOSTAY_APP_DATABASE_PASSWORD=change_me
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_NAME=homostay_app_production
DATABASE_USER=homostay_app
REDIS_URL=redis://redis:6379/0
ACTIVE_STORAGE_SERVICE=s3
ACTIVE_STORAGE_BUCKET=replace_me
ACTIVE_STORAGE_ACCESS_KEY_ID=replace_me
ACTIVE_STORAGE_SECRET_ACCESS_KEY=replace_me
ACTIVE_STORAGE_ENDPOINT=https://storage.railway.app
ACTIVE_STORAGE_REGION=auto
ACTIVE_STORAGE_FORCE_PATH_STYLE=true
