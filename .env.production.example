RAILS_ENV=production
PORT=3000
SERVICE_MODE=web
RUN_SIDEKIQ_IN_WEB=true
RAILS_LOG_LEVEL=info
RAILS_SERVE_STATIC_FILES=1
RAILS_FORCE_SSL=true
APP_HOSTS=thesacredhomes.com,www.thesacredhomes.com

BACKEND_URL=https://thesacredhomes.com
FRONTEND_URL=https://thesacredhomes.com
VITE_FRONTEND_URL=https://thesacredhomes.com
VITE_API_BASE_URL=https://thesacredhomes.com

DATABASE_NAME=homostay_app_production
DATABASE_USER=homostay_app
DATABASE_HOST=postgres
DATABASE_PORT=5432
HOMOSTAY_APP_DATABASE_PASSWORD=change_me

REDIS_URL=redis://redis:6379/0
RAILS_MAX_THREADS=3
RAILS_MIN_THREADS=1
WEB_CONCURRENCY=1
SIDEKIQ_CONCURRENCY=2

# Prefer Railway Bucket variable references (BUCKET, ACCESS_KEY_ID, SECRET_ACCESS_KEY, ENDPOINT, REGION)
# or set the ACTIVE_STORAGE_* names below explicitly.
ACTIVE_STORAGE_SERVICE=s3
ACTIVE_STORAGE_BUCKET=replace_me
ACTIVE_STORAGE_ACCESS_KEY_ID=replace_me
ACTIVE_STORAGE_SECRET_ACCESS_KEY=replace_me
ACTIVE_STORAGE_ENDPOINT=https://storage.railway.app
ACTIVE_STORAGE_REGION=auto
ACTIVE_STORAGE_FORCE_PATH_STYLE=true

ICAL_DOMAIN=thesacredhomes.com
SECRET_KEY_BASE=change-me

WHATSAPP_PHONE_NUMBER_ID=replace_me
WHATSAPP_ACCESS_TOKEN=replace_me
WHATSAPP_BUSINESS_ACCOUNT_ID=replace_me
WHATSAPP_WEBHOOK_VERIFY_TOKEN=replace_me
WHATSAPP_APP_SECRET=replace_me
ADMIN_WHATSAPP_NUMBER=replace_me

SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=change-me

TELEGRAM_BOT_TOKEN=replace_me
TELEGRAM_CHAT_ID=replace_me
